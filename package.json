{
  "private": true,
  "name": "garvitpahal.com",
  "scripts": {
    "prepare": "simple-git-hooks",
    "pre-push": "run-p type-check lint fmt-check && pnpm build && ./scripts/verify-no-git-changes.sh",
    "clean": "rimraf .next",
    "dev": "next dev",
    "build": "run-s build:*",
    "build:process-content": "node --loader esbuild-register/loader -r esbuild-register scripts/process-content.ts",
    "build:app": "cross-env NODE_ENV=production next build",
    "start": "cross-env NODE_ENV=production next start",
    "type-check": "tsc --noEmit",
    "lint": "run-s lint:*",
    "lint:app": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "lint-fix": "run-s lint-fix:*",
    "lint-fix:app": "eslint . --fix",
    "lint-fix:stylelint": "stylelint \"src/**/*.css\" --fix",
    "fmt": "prettier \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,json,md,mdx}\" --write",
    "fmt-check": "prettier \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,json,md,mdx}\" --check"
  },
  "dependencies": {
    "@gpahal/font": "^0.0.3",
    "@gpahal/markdoc-react": "^0.0.10",
    "@gpahal/std": "^0.0.19",
    "@radix-ui/react-tabs": "^1.0.4",
    "@vercel/analytics": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.3",
    "lucide-react": "^0.316.0",
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.33.2",
    "tailwind-merge": "^2.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@gpahal/eslint-config": "^0.0.15",
    "@gpahal/markdoc": "^0.0.61",
    "@gpahal/prettier-config": "^0.0.7",
    "@gpahal/std-node": "^0.0.19",
    "@gpahal/stylelint-config": "^0.0.3",
    "@gpahal/tailwindcss-color-themes": "^0.0.2",
    "@gpahal/tailwindcss-variants": "^0.0.2",
    "@gpahal/tsconfig": "^0.0.11",
    "@next/bundle-analyzer": "^14.1.0",
    "@radix-ui/colors": "^3.0.0",
    "@tailwindcss/typography": "^0.5.10",
    "@total-typescript/ts-reset": "^0.5.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "cross-env": "^7.0.3",
    "cssnano": "^6.0.3",
    "esbuild": "^0.20.0",
    "esbuild-register": "^3.5.0",
    "eslint": "^8.56.0",
    "fs-extra": "^11.2.0",
    "image-size": "^1.1.1",
    "node-fetch": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.33",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.0.0",
    "postcss-preset-env": "^9.3.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "simple-git-hooks": "^2.9.0",
    "stylelint": "^16.2.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3"
  }
}
