{
  "private": true,
  "name": "garvitpahal.com",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prepare": "simple-git-hooks",
    "pre-push": "run-p type-check lint fmt-check && astro check",
    "astro": "astro",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "type-check": "tsc --noEmit",
    "lint": "run-s lint:*",
    "lint:app": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "lint-fix": "run-s lint-fix:*",
    "lint-fix:app": "eslint . --fix",
    "lint-fix:stylelint": "stylelint \"src/**/*.css\" --fix",
    "fmt": "prettier \"**/*.{astro,js,mjs,cjs,jsx,ts,tsx,css,json}\" --write",
    "fmt-check": "prettier \"**/*.{astro,js,mjs,cjs,jsx,ts,tsx,css,json}\" --check"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.3",
    "@astrojs/markdoc": "^0.11.4",
    "@astrojs/rss": "^4.0.7",
    "@astrojs/sitemap": "^3.1.6",
    "@gpahal/eslint-config": "^0.0.54",
    "@gpahal/prettier-config": "^0.0.17",
    "@gpahal/std": "^0.0.23",
    "@gpahal/stylelint-config": "^0.0.11",
    "@gpahal/tailwindcss-color-themes": "^0.0.17",
    "@gpahal/tailwindcss-variants": "^0.0.13",
    "@gpahal/tsconfig": "^0.0.16",
    "@radix-ui/colors": "^3.0.0",
    "@types/node": "^22.7.4",
    "astro": "5.0.0-beta.3",
    "cssnano": "^7.0.6",
    "date-fns": "^4.1.0",
    "eslint": "^9.11.1",
    "npm-run-all2": "^6.2.3",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.0",
    "postcss-preset-env": "^10.0.5",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "sharp": "^0.33.5",
    "simple-git-hooks": "^2.11.1",
    "stylelint": "^16.9.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
