{
  "private": true,
  "name": "garvitpahal.com",
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "pre-push": "run-p type-check lint fmt-check && pnpm build && ./scripts/verify-no-git-changes.sh",
    "clean": "rimraf .next",
    "dev": "next dev",
    "build": "run-s build:*",
    "build:process-content": "tsx scripts/process-content.ts",
    "build:app": "cross-env NODE_ENV=production next build",
    "start": "cross-env NODE_ENV=production next start",
    "type-check": "tsc --noEmit",
    "lint": "run-s lint:*",
    "lint:app": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "lint-fix": "run-s lint-fix:*",
    "lint-fix:app": "eslint . --fix",
    "lint-fix:stylelint": "stylelint \"src/**/*.css\" --fix",
    "fmt": "prettier \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,json,md,mdx}\" --write",
    "fmt-check": "prettier \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,json,md,mdx}\" --check"
  },
  "dependencies": {
    "@gpahal/markdoc-react": "^0.0.17",
    "@gpahal/std": "^0.0.20",
    "@icons-pack/react-simple-icons": "^9.6.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@vercel/analytics": "^1.3.1",
    "@vercel/speed-insights": "^1.0.12",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "feed": "^4.2.2",
    "framer-motion": "^11.3.7",
    "geist": "^1.3.1",
    "lucide-react": "^0.408.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.4",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@gpahal/eslint-config": "^0.0.23",
    "@gpahal/markdoc": "^0.0.69",
    "@gpahal/prettier-config": "^0.0.13",
    "@gpahal/std-node": "^0.0.20",
    "@gpahal/stylelint-config": "^0.0.8",
    "@gpahal/tailwindcss-color-themes": "^0.0.6",
    "@gpahal/tailwindcss-variants": "^0.0.6",
    "@gpahal/tsconfig": "^0.0.15",
    "@next/bundle-analyzer": "^14.2.5",
    "@radix-ui/colors": "^3.0.0",
    "@tailwindcss/typography": "^0.5.13",
    "@total-typescript/ts-reset": "^0.5.1",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "cross-env": "^7.0.3",
    "cssnano": "^7.0.4",
    "eslint": "^8.57.0",
    "image-size": "^1.1.1",
    "node-fetch": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.39",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.0",
    "postcss-preset-env": "^9.6.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.11.1",
    "stylelint": "^16.7.0",
    "tailwindcss": "^3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
