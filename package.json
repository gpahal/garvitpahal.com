{
  "private": true,
  "name": "garvitpahal.com",
  "scripts": {
    "prepare": "simple-git-hooks",
    "pre-push": "run-p type-check lint fmt-check && pnpm build && ./scripts/verify-no-git-changes.sh",
    "clean": "rimraf .next",
    "dev": "next dev",
    "build": "run-s build:*",
    "build:process-content": "node --loader esbuild-register/loader -r esbuild-register scripts/process-content.ts",
    "build:app": "cross-env NODE_ENV=production next build",
    "start": "cross-env NODE_ENV=production next start",
    "type-check": "tsc --noEmit",
    "lint": "run-s lint:*",
    "lint:app": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "lint-fix": "run-s lint-fix:*",
    "lint-fix:app": "eslint . --fix",
    "lint-fix:stylelint": "stylelint \"src/**/*.css\" --fix",
    "fmt": "prettier \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,json,md,mdx}\" --write",
    "fmt-check": "prettier \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,json,md,mdx}\" --check"
  },
  "dependencies": {
    "@gpahal/font": "^0.0.3",
    "@gpahal/markdoc-react": "^0.0.9",
    "@gpahal/std": "^0.0.19",
    "@radix-ui/react-tabs": "^1.0.4",
    "@vercel/analytics": "^1.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.15.1",
    "lucide-react": "^0.265.0",
    "next": "^13.4.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.32.4",
    "tailwind-merge": "^1.14.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@gpahal/eslint-config": "^0.0.14",
    "@gpahal/markdoc": "^0.0.60",
    "@gpahal/prettier-config": "^0.0.6",
    "@gpahal/std-node": "^0.0.19",
    "@gpahal/stylelint-config": "^0.0.2",
    "@gpahal/tailwindcss-color-themes": "^0.0.1",
    "@gpahal/tailwindcss-variants": "^0.0.1",
    "@gpahal/tsconfig": "^0.0.11",
    "@next/bundle-analyzer": "^13.4.13",
    "@radix-ui/colors": "^2.0.1",
    "@tailwindcss/typography": "^0.5.9",
    "@total-typescript/ts-reset": "^0.4.2",
    "@types/fs-extra": "^11.0.1",
    "@types/node": "^20.4.9",
    "@types/react": "^18.2.19",
    "@types/react-dom": "^18.2.7",
    "cross-env": "^7.0.3",
    "cssnano": "^6.0.1",
    "esbuild": "^0.19.0",
    "esbuild-register": "^3.4.2",
    "eslint": "^8.46.0",
    "fs-extra": "^11.1.1",
    "image-size": "^1.0.2",
    "node-fetch": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.27",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^15.1.0",
    "postcss-preset-env": "^9.1.1",
    "prettier": "^3.0.1",
    "rimraf": "^5.0.1",
    "simple-git-hooks": "^2.9.0",
    "stylelint": "^15.10.2",
    "tailwindcss": "^3.3.3",
    "tailwindcss-animate": "^1.0.6",
    "typescript": "^5.1.6"
  }
}
