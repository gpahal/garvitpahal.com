{
  "private": true,
  "name": "garvitpahal.com",
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "pre-push": "run-p type-check lint fmt-check && astro check",
    "astro": "astro",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "type-check": "tsc --noEmit",
    "lint": "run-s lint:*",
    "lint:app": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "lint-fix": "run-s lint-fix:*",
    "lint-fix:app": "eslint . --fix",
    "lint-fix:stylelint": "stylelint \"src/**/*.css\" --fix",
    "fmt": "prettier \"**/*.{astro,js,mjs,cjs,jsx,ts,tsx,css,json}\" --write",
    "fmt-check": "prettier \"**/*.{astro,js,mjs,cjs,jsx,ts,tsx,css,json}\" --check"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/markdoc": "^0.13.2",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.3.0",
    "@gpahal/eslint-config": "^0.0.58",
    "@gpahal/prettier-config": "^0.0.19",
    "@gpahal/std": "^0.0.25",
    "@gpahal/stylelint-config": "^0.0.16",
    "@gpahal/tailwindcss-color-themes": "^0.0.20",
    "@gpahal/tailwindcss-variants": "^0.0.16",
    "@gpahal/tsconfig": "^0.0.16",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@radix-ui/colors": "^3.0.0",
    "@types/node": "^22.13.14",
    "astro": "^5.5.5",
    "cssnano": "^7.0.6",
    "date-fns": "^4.1.0",
    "eslint": "^9.23.0",
    "npm-run-all2": "^7.0.2",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.0",
    "postcss-preset-env": "^10.1.5",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rimraf": "^6.0.1",
    "sharp": "^0.33.5",
    "simple-git-hooks": "^2.12.1",
    "stylelint": "^16.17.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "simple-git-hooks"
    ]
  }
}
